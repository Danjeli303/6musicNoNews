# Temporary DNS for first AWS testing.
# Replace 203.0.113.10 with your EC2 public IPv4 address.
PUBLIC_HOST=203.0.113.10.sslip.io

# Keep these simple for URL compatibility: letters, numbers, dashes, underscores.
ICECAST_SOURCE_PASSWORD=change-this-source-password
ICECAST_RELAY_PASSWORD=change-this-relay-password
ICECAST_ADMIN_PASSWORD=change-this-admin-password
ICECAST_ADMIN_EMAIL=you@example.com
ICECAST_LOCATION=AWS

# Optional stream tuning.
AWS_AUDIO_BITRATE=128k
FIP_VOLUME=0.85
DUCK_THRESHOLD=0.002
DUCK_RATIO=20
FIP_FADE_OUT_MS=700
FIP_FADE_IN_MS=1800

